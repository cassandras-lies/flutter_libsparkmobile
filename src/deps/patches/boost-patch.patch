-
-mkdir -p ${tmp_dir}/extract
-cd ${tmp_dir}/extract
-echo "Extracting archive..."
-tar xf ${tmp_dir}/boost_${BOOST_VERSION}.tar.bz2
-
-cd boost_*
-
-if [ -d "${patch_dir}" ]; then
-  mkdir patch
